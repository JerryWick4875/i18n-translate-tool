{
  "name": "i18n-tool",
  "version": "1.0.0",
  "description": "i18n translation sync and snapshot tool",
  "main": "dist/index.js",
  "bin": {
    "i18n-tool": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "test": "ts-node src/__tests__/index.ts"
  },
  "keywords": [
    "i18n",
    "translation",
    "sync",
    "snapshot",
    "yaml",
    "typescript",
    "commander"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "commander": "^11.1.0",
    "glob": "^10.3.0",
    "js-yaml": "^4.1.0",
    "zod": "^4.3.6"
  }
}
